{# macros.html.j2 — small reusable bits.

   render_datatable: generic table renderer. The Python builder passes ordered
   `columns` and a list of `rows` (each a dict keyed by column name). We render
   plain HTML <table> with a stable id; JS in sample_report.html.j2 promotes
   each one to a DataTable.

   render_variant_table: same as render_datatable but adds:
     - data-verdict attribute on <tr> (used to mute REJECT rows)
     - data-igv-key attribute on <tr> (phase 4 will use this for click-jump)
#}

{% macro render_datatable(table_id, columns, rows, col_vis=False) -%}
<div class="table-responsive">
  <table id="{{ table_id }}" class="table table-sm table-striped table-hover w-100">
    <thead>
      <tr>{% for c in columns %}<th>{{ c }}</th>{% endfor %}</tr>
    </thead>
    <tbody>
      {% for r in rows %}
        <tr>{% for c in columns %}<td>{{ r[c] | default('', true) }}</td>{% endfor %}</tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{%- endmacro %}

{% macro render_variant_table(table_id, columns, rows, igv_lookup=None) -%}
<div class="table-responsive">
  <table id="{{ table_id }}" class="table table-sm table-striped table-hover w-100">
    <thead>
      <tr>{% for c in columns %}<th>{{ c }}</th>{% endfor %}</tr>
    </thead>
    <tbody>
      {% for r in rows %}
        {%- set verdict = r.get('SomaticSeq_Verdict', '') -%}
        {%- set igv_key = (r.get('Chr', '') ~ ':' ~ r.get('Start', '') ~ ':' ~ r.get('Ref', '') ~ ':' ~ r.get('Alt', '')) -%}
        <tr data-verdict="{{ verdict }}" data-igv-key="{{ igv_key }}">
          {% for c in columns %}<td>{{ r[c] | default('', true) }}</td>{% endfor %}
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{%- endmacro %}

{# render_cnv_plot_card: One CNV plot rendered as a card with an
   "Include in report" checkbox. The plot_id is the durable key the
   Reporting tab uses to recall this plot (e.g. 'per_gene::TP53'); it
   must be unique within a sample and stable across rebuilds. The label
   is the human-readable caption shown above the image. The col_class
   controls Bootstrap grid width (e.g. 'col-md-6 col-xl-4'). #}
{% macro render_cnv_plot_card(plot_id, label, path, col_class='col-md-6') -%}
<div class="{{ col_class }}">
  <div class="card vb-cnv-card h-100" data-cnv-plot-id="{{ plot_id }}" data-cnv-path="{{ path }}" data-cnv-label="{{ label }}">
    <div class="card-header d-flex justify-content-between align-items-center py-2">
      <span class="small fw-medium text-truncate" title="{{ label }}">{{ label }}</span>
      <label class="form-check form-check-inline mb-0 vb-cnv-select-label" title="Include in Reporting tab">
        <input type="checkbox" class="form-check-input vb-cnv-select" data-cnv-plot-id="{{ plot_id }}">
        <span class="form-check-label small text-muted ms-1">Include</span>
      </label>
    </div>
    <div class="card-body p-2">
      <a href="./{{ path }}" target="_blank" rel="noopener" title="Open full size in new tab">
        <img src="./{{ path }}" alt="{{ label }}" class="img-fluid border rounded" loading="lazy" style="display:block;width:100%">
      </a>
    </div>
  </div>
</div>
{%- endmacro %}
