/*
 * nf-core-tspipe nextflow.config
 *
 * Parameter defaults mirror run_sample_pipeline.py:
 *   - reference     -> --reference
 *   - bed           -> --bed
 *   - input         -> samplesheet replacing --fastq-dir + sample discovery
 *   - cnv_pon       -> --pon
 *   - cnv_loo_*     -> --loo-summary, --noise-profile
 *   - snv_blacklist -> --blacklist-snvs
 */

params {
    // ---- Input -----------------------------------------------------------
    input              = null   // samplesheet CSV (see assets/schema_input.json)
    outdir             = "/goast/hemat_data/nfcore_runs/default"
    keep_intermediates = false
    panel_name         = "MYOPOOL hg38"

    // ---- Reference / panel ----------------------------------------------
    reference          = null   // hg38 masked FASTA
    panel              = 'myeloid'   // panel name; drives references/<panel>/ output namespacing
    male_reference     = true        // pass -y to cnvkit (haploid X reference); set false for female-only PoN
    chrx_threshold     = null        // chrX log2 cutoff for BUILD_SEX_PON sex classification;
                                     // null => derived from male_reference (+0.5 if -y, else -0.5)
    bed                = null   // panel BED
    exonwise_bed       = null   // exon-collapsed BED for mosdepth only
    pindel_bed         = null   // optional - pindel target subset
    adapters           = null   // illumina_adapters.fa

    // ---- CNV resources --------------------------------------------------
    // nf-core CNV wiring v1 (apply_nfcore_cnv_wiring_part1)
    cnv_pon            = null   // DEPRECATED: mixed-sex PoN. Kept for back-
                                //   compat; ignored when meta.sex is set.
    cnv_pon_male       = null   // assets/${panel}/cnvkit_pon_male.cnn fallback
    cnv_pon_female     = null   // assets/${panel}/cnvkit_pon_female.cnn fallback
    cnv_loo_summary    = null   // assets/${panel}/cnvkit_loo_summary.tsv fallback
    cnv_noise_profile  = null   // assets/${panel}/loo_bin_noise_profile.tsv fallback
    cnv_noisy_bins     = null   // assets/${panel}/cnvkit_noisy_bins.bed fallback

    // ---- Annotation references -----------------------------------------
    cytoband           = null   // assets/references/cytoBand_hg38.txt fallback
    clingen            = null   // assets/references/ClinGen_gene_curation_list_GRCh38.tsv fallback

    // ---- Blacklist ------------------------------------------------------
    snv_blacklist      = "${projectDir}/references/blacklist_file.tsv"   // 11-column schema; matcher in bin/apply_blacklist.py

    // ---- Annotation -----------------------------------------------------
    vep_cache          = null
    annovar_script     = null   // path to ANNOVAR's table_annovar.pl
    annovar_db         = null

    // ---- Legacy production-tree fallback --------------------------------
    // Three annotation modules (VARIANT_VALIDATOR, ONCOVI, FLT3_TO_VARIANTS)
    // currently shell out to Python scripts in the legacy production tree,
    // using the conda environment installed alongside it. Until those
    // scripts are containerised, sites must either replicate the legacy
    // tree at the default paths below, or override both params (typically
    // in conf/<yoursite>.config) to point at their own copies.
    //
    // See docs/INSTALL.md ("Legacy production-tree dependency") for the
    // site-override workflow.
    legacy_root        = '/home/hemat/targeted-seq-pipeline'
    legacy_python_env  = '/home/hemat/anaconda3/envs/targeted-seq'
    // OncoVI third-party install (engine in src/, data in resources/). Kept
    // external like ANNOVAR/Strelka2; defaults to its current location under
    // legacy_root/software. Override per site.
    oncovi_dir         = "${params.legacy_root}/software/oncovi"
    // ---- Dashboard GeneBe annotation (opt-in) ------------------------
    // GeneBe (https://genebe.net) adds ACMG classification, ClinVar
    // status, and gnomAD frequencies to the dashboard's Variants tab.
    // Defaults below keep the feature disabled. To enable, set
    // genebe_enabled = true and provide the credentials via the
    // credentials.config file loaded at the bottom of this file (NOT
    // here, so the key never lands in version control).
    genebe_enabled = false
    genebe_user    = null
    genebe_key     = null

    // ---- Dashboard OncoKB annotation (opt-in) ------------------------
    // OncoKB (https://www.oncokb.org) provides precision-oncology
    // annotations for clinical variants. Free academic tokens are
    // available at https://www.oncokb.org/account/register.
    // Set oncokb_enabled = true and provide the token via the
    // credentials.config file (NOT here).
    oncokb_enabled = false
    oncokb_token   = null

    dashboard_python   = null

    // ---- Pipeline behaviour --------------------------------------------
    flt3_container     = 'docker'   // 'docker' or 'singularity'
    flt3_region        = 'chr13:28003000-28101000'  // hg38 FLT3 transcript + flanking (D1)

    // ---- Resources ------------------------------------------------------
    max_memory         = '128.GB'
    max_cpus           = 16
    max_time           = '240.h'

    // ---- nf-core conventions -------------------------------------------
    publish_dir_mode   = 'link'
    monochrome_logs    = false
    help               = false
    version            = false
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------
profiles {

    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled    = true
        docker.userEmulation = true
        singularity.enabled = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

    conda {
        conda.enabled = true
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    // ---- Site profiles -------------------------------------------------
    // Copy conf/site_template.config to conf/<yoursite>.config and register
    // it here. See docs/deployment.md for the checklist.

    gandalf {
        includeConfig 'conf/gandalf.config'
    }
}

// ---------------------------------------------------------------------------
// Process resource defaults + per-module overrides
// ---------------------------------------------------------------------------
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ---------------------------------------------------------------------------
// Reporting
// ---------------------------------------------------------------------------
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
    overwrite = true
}
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.svg"
    overwrite = true
}

manifest {
    name            = 'nf-core-tspipe'
    homePage        = 'https://github.com/patkarlab/nf-core-tspipe'
    description     = 'Targeted sequencing pipeline for leukemia / myeloid panels'
    mainScript      = 'main.nf'
    nextflowVersion = '>=25.10.0'
    version         = '0.1.0dev'
}

// ---- GeneBe credentials (untracked) -------------------------------
// Loads ~/.config/nf-core-tspipe/credentials.config when present,
// overriding the genebe_enabled / genebe_user / genebe_key params
// declared in the params { ... } block above. The credentials file
// is git-ignored and intended to live in the user's home dir at
// mode 0600.
if (new File("${System.getProperty('user.home')}/.config/nf-core-tspipe/credentials.config").exists()) {
    includeConfig "${System.getProperty('user.home')}/.config/nf-core-tspipe/credentials.config"
}
