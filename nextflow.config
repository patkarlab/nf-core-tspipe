/*
 * nf-core-tspipe nextflow.config
 *
 * Parameter defaults mirror run_sample_pipeline.py:
 *   - reference     -> --reference
 *   - bed           -> --bed
 *   - input         -> samplesheet replacing --fastq-dir + sample discovery
 *   - cnv_pon       -> --pon
 *   - cnv_loo_*     -> --loo-summary, --noise-profile
 *   - snv_blacklist -> --blacklist-snvs
 */

params {
    // ---- Input -----------------------------------------------------------
    input              = null   // samplesheet CSV (see assets/schema_input.json)
    outdir             = "results"

    // ---- Reference / panel ----------------------------------------------
    reference          = null   // hg38 masked FASTA
    bed                = null   // panel BED
    pindel_bed         = null   // optional - pindel target subset
    adapters           = null   // illumina_adapters.fa

    // ---- CNV resources --------------------------------------------------
    cnv_pon            = null   // cnvkit_pon/pon_reference.cnn
    cnv_loo_summary    = null   // cnvkit_loo_summary.tsv
    cnv_noise_profile  = null   // loo_bin_noise_profile.tsv
    cnv_noisy_bins     = null   // cnvkit_noisy_bins.bed

    // ---- Blacklist ------------------------------------------------------
    snv_blacklist      = null   // references/blacklist_snvs_hg38.tsv

    // ---- Annotation -----------------------------------------------------
    vep_cache          = null
    annovar_db         = null

    // ---- Pipeline behaviour --------------------------------------------
    skip_from          = 0      // matches --skip-from in the Python runner
    flt3_container     = 'docker'   // 'docker' or 'singularity'

    // ---- Resources ------------------------------------------------------
    max_memory         = '128.GB'
    max_cpus           = 16
    max_time           = '240.h'

    // ---- nf-core conventions -------------------------------------------
    publish_dir_mode   = 'copy'
    monochrome_logs    = false
    help               = false
    version            = false
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------
profiles {

    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled    = true
        docker.userEmulation = true
        singularity.enabled = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

    conda {
        conda.enabled = true
    }

    test {
        includeConfig 'conf/test.config'
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    // ---- Site profiles -------------------------------------------------
    // Copy conf/site_template.config to conf/<yoursite>.config and register
    // it here. See docs/deployment.md for the checklist.

    gandalf {
        includeConfig 'conf/gandalf.config'
    }
}

// ---------------------------------------------------------------------------
// Process resource defaults + per-module overrides
// ---------------------------------------------------------------------------
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ---------------------------------------------------------------------------
// Reporting
// ---------------------------------------------------------------------------
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
    overwrite = true
}
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.svg"
    overwrite = true
}

manifest {
    name            = 'nf-core-tspipe'
    homePage        = 'https://github.com/your-org/nf-core-tspipe'
    description     = 'Targeted sequencing pipeline for leukemia / myeloid panels'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0dev'
}
