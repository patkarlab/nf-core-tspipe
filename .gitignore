# Nextflow runtime artifacts
work/
.nextflow/
.nextflow.log*
.nextflow.history

# Test run outputs (BAMs, reports, results)
test_run/
results/

# Singularity cache (shared between projects, never commit)
singularity_cache/

# Editor temp files
*.swp
*.swo
*~
.DS_Store

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Local secrets/credentials
.env
.secrets

# OS-generated junk
Thumbs.db

# tmux debug logs
tmux-*.log

# Local backup files (e.g. *.bak.YYYYMMDD_HHMMSS or *.bak_<tag>)
*.bak.*
*.bak_*

# Zero-byte stray files matching subworkflow names — appeared 2026-05-19
# from an unknown source. Defensive ignore so they can't be staged.
/ANNOTATION
/CNV_CALLING
/FLT3_ITD
/REPORTING
/SOMATICSEQ_ENSEMBLE
/SV_CALLING
/VARIANT_CALLING

