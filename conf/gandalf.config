/*
 * conf/gandalf.config
 *
 * Site profile for the gandalf server. Captures every gandalf-specific path
 * extracted from the original scripts/run_sample_pipeline.py and friends.
 *
 * Strategy on gandalf: use the existing conda envs and tool installs rather
 * than pulling containers (most tools are already on disk, Docker disk is
 * known to fill up). Only FLT3_ITD_EXT and DeepSomatic stay containerized
 * because that's how the originals ran.
 *
 * To use:
 *     nextflow run main.nf -profile gandalf,singularity --input samplesheet.csv
 *
 * To move to another server: copy this file to conf/yoursite.config, change
 * the paths, and run with -profile yoursite,singularity (or docker).
 */

// ---------------------------------------------------------------------------
// Default param values for gandalf
// ---------------------------------------------------------------------------
params {
    // The original pipeline root
    pipeline_root      = '/goast/hemat_data/targeted-seq-pipeline'

    // References (masked GRCh38)
    reference          = "${params.pipeline_root}/references/hg38_broad/Homo_sapiens_assembly38.masked.fasta"
    bed                = "${params.pipeline_root}/bedfiles/MYOPOOL_240125_UBTF_hg38.bed"
    pindel_bed         = "${projectDir}/references/pindel_targets_flt3_ubtf.bed"
    adapters           = "${params.pipeline_root}/references/illumina_adapters.fa"

    // CNV resources: defaulted from ${projectDir}/assets/${params.panel}/
    // in workflows/tspipe.nf. Override here only if a non-asset path is
    // required (e.g. pointing at a freshly-rebuilt PoN before assets are seeded).

    // SNV blacklist
    dbsnp_vcf          = "/goast/hemat_data/references/dbSNPGATK_hg38/Homo_sapiens_assembly38.dbsnp138.vcf.gz"
    mills_vcf          = "/goast/hemat_data/references/dbSNPGATK_hg38/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"

    // gnomAD AF-only VCF for Mutect2 germline filtering
    gnomad_af_only     = "/goast/hemat_data/references/dbSNPGATK_hg38/af-only-gnomad.hg38.vcf.gz"

    snv_blacklist      = "${params.pipeline_root}/references/blacklist_snvs_hg38.tsv"

    // Annotation databases
    vep_cache          = "${params.pipeline_root}/references/vep_cache"
    annovar_db         = "${params.pipeline_root}/references/annovar_db"

    // FLT3 ensemble: container runtime ('docker' or 'singularity')
    flt3_container     = 'singularity'

    // External tool installs (non-conda)
    vardict_bin        = '/goast/hemat_data/programs/VarDictJava/build/install/VarDict/bin/VarDict'
    getitd_path        = '/home/hemat/programs/getitd/getitd.py'
    filt3r_bin         = '/home/hemat/programs/filt3r/filt3r'
    filt3r_ref         = '/home/hemat/programs/filt3r/data/flt3_exon14-15.fa'

    // Resource ceilings (gandalf has 16+ cores)
    max_memory         = '128.GB'
    max_cpus           = 16
    max_time           = '48.h'
}

// ---------------------------------------------------------------------------
// Conda envs: use the existing ones on gandalf, do NOT create new ones
// ---------------------------------------------------------------------------
conda {
    enabled            = false   // we DON'T want Nextflow to manage envs here
}

env {
    // The targeted-seq env already has fastp, bwa, samtools, gatk4, abra2,
    // cnvkit, freebayes, vardict, varscan, somaticseq, pysam, pandas, numpy.
    // Put it first on PATH so all module processes find these tools.
    TARGETED_SEQ_ENV   = '/home/hemat/anaconda3/envs/targeted-seq'
    // The py2 env for Strelka and Platypus.
    PY2_ENV            = '/home/hemat/anaconda3/envs/py2'
}

// Make the conda bin available inside every process
process {
    beforeScript = '''
        export PATH=/home/hemat/anaconda3/envs/targeted-seq/bin:$PATH
    '''

    withName: 'DEEPSOMATIC' {
        // Neural-net inference is slow; give it longer + memory headroom
        time   = '6.h'
        memory = '32.GB'
    }
}

// ---------------------------------------------------------------------------
// Per-process overrides for gandalf-specific tool locations
// ---------------------------------------------------------------------------
process {

    // Strelka and Platypus need the py2 env
    withName: 'STRELKA' {
        // Strelka2 needs python2 + the configureStrelkaGermlineWorkflow.py script
        ext.python2     = '/home/hemat/anaconda3/envs/py2/bin/python'
        ext.strelka_bin = '/goast/hemat_data/targeted-seq-pipeline/software/strelka2/bin/configureStrelkaGermlineWorkflow.py'
        // py2 env needs to be on PATH for strelka's internal subprocess calls too
        beforeScript    = 'export PATH=/home/hemat/anaconda3/envs/py2/bin:$PATH'
    }
    withName: 'PLATYPUS' {
        // Platypus is a py2 tool; conda wrapper handles invocation when py2/bin is on PATH first
        beforeScript = 'export PATH=/home/hemat/anaconda3/envs/py2/bin:$PATH'
    }

    // VarDict is a binary outside the conda env
    withName: 'VARDICT' {
        // teststrandbias.R and var2vcf_valid.pl ship inside the VarDictJava install
        ext.vardict_helpers_dir = '/goast/hemat_data/programs/VarDictJava/build/install/VarDict/bin'
    }

    // Site decision: VarScan at 3% VAF (production: 0.3%). Clinical interest
    // below 3% is rare on this panel and the 0.3% threshold produced noise
    // that SomaticSeq filtered out anyway. Documented in docs/clinical_decisions.md.
    withName: 'VARSCAN' {
        ext.min_var_freq = '0.03'
    }

    // FLT3 tools that aren't on conda
    withName: 'GETITD' {
        ext.getitd_path = params.getitd_path
    }
    withName: 'FILT3R' {
        ext.filt3r_bin  = params.filt3r_bin
        ext.filt3r_ref  = params.filt3r_ref
    }
}

// ---------------------------------------------------------------------------
// Executor: run on the local machine, not slurm/sge
// ---------------------------------------------------------------------------
process.executor = 'local'

// Limit concurrent processes so we don't exhaust gandalf during a test.
// Bump this once you're confident in the configuration.
executor {
    name           = 'local'
    cpus           = 16
    memory         = '64 GB'
    queueSize      = 8
}

// ---------------------------------------------------------------------------
// Singularity: gandalf has docker but the disk fills up, so prefer singularity
// ---------------------------------------------------------------------------
singularity {
    enabled        = true
    autoMounts     = true
    cacheDir       = "${params.pipeline_root}/singularity_cache"
    pullTimeout = '60m'
    runOptions     = '--no-home'
}

docker {
    enabled        = false
}
