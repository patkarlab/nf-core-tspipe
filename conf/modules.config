/*
 * conf/modules.config
 *
 * Per-module publishDir + ext.args. nf-core convention: keep tool-specific
 * arguments out of the module body so changes don't require module edits.
 */

process {

    // ---- Preprocessing -------------------------------------------------
    withName: 'FASTP' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/trimmed" },
            mode: params.publish_dir_mode,
            pattern: '*.{fastq.gz,html,json}'
        ]
        ext.args = '--detect_adapter_for_pe'
    }

    withName: 'BWA_MEM' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/aligned" },
            mode: params.publish_dir_mode,
            pattern: '*.bam'
        ]
        ext.args  = '-M'
    }

    withName: 'PICARD_MARKDUPLICATES' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/markdup" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai,metrics.txt}'
        ]
    }

    withName: 'GATK4_BQSR' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bqsr" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai,table}'
        ]
    }

    withName: 'ABRA2' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/abra2" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai}'
        ]
        ext.args = '--mer 0.025 --mad 5000'
    }

    // ---- Variant calling -----------------------------------------------
    withName: 'GATK4_MUTECT2' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/mutect2" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'SOMATICSEQ_ENSEMBLE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/somaticseq" },
            mode: params.publish_dir_mode
        ]
    }


    withName: 'VARDICT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/vardict" },
            mode: params.publish_dir_mode,
            pattern: '*.{vcf,tsv}'
        ]
    }

    withName: 'VARSCAN' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/varscan" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'FREEBAYES' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/freebayes" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'STRELKA' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/strelka" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'PLATYPUS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/platypus" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'PINDEL' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/pindel" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'DEEPSOMATIC' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/deepsomatic" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf.gz*'
        ]
    }

    withName: 'U2AF1_RESCUE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/u2af1_rescue" },
            mode: params.publish_dir_mode
        ]
    }
    // ---- FLT3-ITD ensemble ---------------------------------------------
    withName: 'FLT3_ITD_EXT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3/flt3_itd_ext" },
            mode: params.publish_dir_mode
        ]
        container = 'zhkddocker/flt3_itd_ext:v1.1'
    }
    withName: 'FILT3R' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3/filt3r" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'GETITD' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3/getitd" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'FLT3_CONSENSUS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3" },
            mode: params.publish_dir_mode
        ]
    }

    // ---- CNV -----------------------------------------------------------
    withName: 'CNVKIT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cnv/cnvkit" },
            mode: params.publish_dir_mode
        ]
    }

    // ---- Annotation ----------------------------------------------------
    withName: 'VEP_ANNOTATE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/annotation" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'VARIANT_FILTER' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/annotation" },
            mode: params.publish_dir_mode,
            pattern: '*.{tsv,clinical.tsv,filtered.tsv}'
        ]
    }

    // ---- Output organization -------------------------------------------
    withName: 'ORGANIZE_OUTPUT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/deliverables" },
            mode: params.publish_dir_mode
        ]
    }

    // ---- PoN build (BUILD_PON entry workflow) --------------------------
    // These ship final PoN artefacts into ${params.outdir}/pon/ where the
    // user can grab them and wire them into the main pipeline as
    // --cnv_pon / --cnv_loo_summary / --cnv_noise_profile / --cnv_noisy_bins.
    withName: 'CNVKIT_PON_BUILD' {
        publishDir = [
            path: { "${params.outdir}/pon" },
            mode: params.publish_dir_mode,
            pattern: 'cnvkit_pon_build/pon_reference.cnn'
        ]
    }
    withName: 'CNV_LOO_QC' {
        // publishDir-namespaced-refs: split outputs into two publish locations.
        //   (a) references/<panel>/ artifacts -> ${params.outdir}/references/<panel>/
        //   (b) per-run QC artifacts          -> ${params.outdir}/pon/loo_qc/
        publishDir = [
            [
                path: { "${params.outdir}/references/${params.panel}" },
                mode: params.publish_dir_mode,
                pattern: 'references/*/cnvkit_*'
            ],
            [
                path: { "${params.outdir}/pon/loo_qc" },
                mode: params.publish_dir_mode,
                pattern: 'loo_qc/**'
            ]
        ]
    }
    withName: 'BUILD_SEX_PON' {
        publishDir = [
            path: { "${params.outdir}/pon" },
            mode: params.publish_dir_mode,
            pattern: '{cnvkit_pon_male.cnn,cnvkit_pon_female.cnn,cnvkit_pon_sex_assignment.tsv}'
        ]
    }
}
