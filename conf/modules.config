/*
 * conf/modules.config
 *
 * Per-module publishDir + ext.args. nf-core convention: keep tool-specific
 * arguments out of the module body so changes don't require module edits.
 */

process {

    // ---- Preprocessing -------------------------------------------------
    withName: 'FASTP' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/trimmed" },
            mode: params.publish_dir_mode,
            pattern: '*.{fastq.gz,html,json}'
        ]
        ext.args = '--detect_adapter_for_pe'
    }

    withName: 'BWA_MEM' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/aligned" },
            mode: params.publish_dir_mode,
            pattern: '*.bam'
        ]
        ext.args  = '-M'
    }

    withName: 'PICARD_MARKDUPLICATES' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/markdup" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai,metrics.txt}'
        ]
    }

    withName: 'GATK4_BQSR' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bqsr" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai,table}'
        ]
    }

    withName: 'ABRA2' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/abra2" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai}'
        ]
        ext.args = '--mer 0.025 --mad 5000'
    }

    withName: 'HSMETRICS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/hsmetrics" },
            mode: params.publish_dir_mode,
            pattern: '*.{txt,interval_list}'
        ]
    }

    withName: 'MOSDEPTH' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/mosdepth" },
            mode: params.publish_dir_mode,
            pattern: '*.{bed.gz,bed.gz.csi,summary.txt,dist.txt}'
        ]
    }

    withName: 'PARSE_EXON_COVERAGE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/exon_coverage" },
            mode: params.publish_dir_mode,
            pattern: '*.tsv'
        ]
    }

    // ---- Variant calling -----------------------------------------------
    withName: 'GATK4_MUTECT2' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/mutect2" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'SOMATICSEQ_ENSEMBLE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/somaticseq" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'SOMATICSEQ_POSTPROCESS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/somaticseq" },
            mode: params.publish_dir_mode
        ]
    }


    withName: 'VARDICT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/vardict" },
            mode: params.publish_dir_mode,
            pattern: '*.{vcf,tsv}'
        ]
    }

    withName: 'VARSCAN' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/varscan" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'FREEBAYES' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/freebayes" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'STRELKA' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/strelka" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'PLATYPUS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/platypus" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'PINDEL' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/pindel" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf'
        ]
    }

    withName: 'DEEPSOMATIC' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/deepsomatic" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf.gz*'
        ]
    }

    withName: 'U2AF1_RESCUE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variant_callers/u2af1_rescue" },
            mode: params.publish_dir_mode
        ]
    }
    // ---- FLT3-ITD ensemble ---------------------------------------------
    withName: 'FLT3_ITD_EXT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3/flt3_itd_ext" },
            mode: params.publish_dir_mode
        ]
        // Container is set to match modules/local/flt3_itd_ext.nf
        // (the v0.2 overlay with /usr/local/bin/flt3_itd_ext wrapper).
        // Keeping both in sync is necessary because withName selectors
        // override module-level container directives.
        container = 'local/flt3_itd_ext:v0.2'
    }
    withName: 'FILT3R' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3/filt3r" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'GETITD' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3/getitd" },
            mode: params.publish_dir_mode
        ]
    }
    withName: 'FLT3_CONSENSUS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/flt3" },
            mode: params.publish_dir_mode
        ]
    }

    // ---- CNV -----------------------------------------------------------
    // nf-core CNV wiring v1 (apply_nfcore_cnv_wiring_part1)
    withName: 'CNVKIT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cnv/cnvkit" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'ZSCORE_CNV' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cnv/zscore" },
            mode: params.publish_dir_mode,
            pattern: '*.tsv'
        ]
    }

    withName: 'CNV_PLOTS' {
        // Two locations: top-level PDFs go directly under cnv/plots/, the
        // detailed plots/ subtree (combined, overview, per_chromosome,
        // per_gene) lands under cnv/plots/details/.
        publishDir = [
            [
                path: { "${params.outdir}/${meta.id}/cnv/plots" },
                mode: params.publish_dir_mode,
                pattern: '*.pdf'
            ],
            [
                path: { "${params.outdir}/${meta.id}/cnv/plots/details" },
                mode: params.publish_dir_mode,
                pattern: 'plots/**',
                saveAs: { fn -> fn.startsWith('plots/') ? fn.substring(6) : fn }
            ]
        ]
    }

    withName: 'CNV_CONCORDANCE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cnv/concordance" },
            mode: params.publish_dir_mode,
            pattern: '*.tsv'
        ]
    }

    withName: 'CNV_CLINICAL_REPORT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cnv/report" },
            mode: params.publish_dir_mode,
            pattern: '*.{tsv,txt}'
        ]
    }

    withName: 'CNV_ANNOTATE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/cnv/annotated" },
            mode: params.publish_dir_mode,
            pattern: '*.tsv'
        ]
    }

    // ---- Annotation ----------------------------------------------------
    withName: 'VEP_ANNOTATE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/annotation" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'VARIANT_FILTER' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/annotation" },
            mode: params.publish_dir_mode,
            pattern: '*.{tsv,clinical.tsv,filtered.tsv}'
        ]
    }

    // ---- Legacy-tree modules: run on host via production conda env ------
    // These three modules invoke scripts at ${params.legacy_root}/scripts/
    // through ${params.legacy_python_env}/bin/python (defaults set in
    // nextflow.config).
    // They REQUIRE host-local execution (no singularity wrap) because:
    //   - VARIANT_VALIDATOR needs localhost:5001 (host network)
    //   - ONCOVI needs ${params.legacy_root}/software/oncovi/ on host fs
    //   - FLT3_TO_VARIANTS is grouped for consistency; it has no hard
    //     host dependency and is the easiest of the three to containerise
    //     when there's time.
    // TODO: containerize properly. FLT3_TO_VARIANTS first (pure stdlib),
    // then ONCOVI (needs resources bundled or bind-mounted), then
    // VARIANT_VALIDATOR (needs the REST stack reachable from the
    // container network).
    withName: 'VARIANT_VALIDATOR|ONCOVI|FLT3_TO_VARIANTS' {
        executor   = 'local'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/annotation" },
            mode: params.publish_dir_mode,
        ]
    }

    // ---- Output organization -------------------------------------------
    withName: 'ORGANIZE_OUTPUT' {
        // Clinical deliverable tree. Explicitly mode='copy' (NOT the
        // global params.publish_dir_mode which resolves to 'link' and
        // silently falls back to symlinks in this environment). Every
        // run must produce self-contained byte copies under
        // <outdir>/<sample>/clinical/ so deliverables SFTP cleanly
        // and survive workflow.onComplete cleanup of work/.
        publishDir = [
            path: { "${params.outdir}/${meta.id}" },
            mode: 'copy'
        ]
    }

    // ---- PoN build (BUILD_PON entry workflow) --------------------------
    // These ship final PoN artefacts into ${params.outdir}/pon/ where the
    // user can grab them and wire them into the main pipeline as
    // --cnv_pon / --cnv_loo_summary / --cnv_noise_profile / --cnv_noisy_bins.
    withName: 'CNVKIT_PON_BUILD' {
        publishDir = [
            path: { "${params.outdir}/pon" },
            mode: params.publish_dir_mode,
            pattern: 'cnvkit_pon_build/pon_reference.cnn'
        ]
    }
    withName: 'CNV_LOO_QC' {
        // publishDir-namespaced-refs: split outputs into two publish locations.
        //   (a) references/<panel>/ artifacts -> ${params.outdir}/references/<panel>/
        //   (b) per-run QC artifacts          -> ${params.outdir}/pon/loo_qc/
        publishDir = [
            [
                path: { "${params.outdir}/references/${params.panel}" },
                mode: params.publish_dir_mode,
                pattern: 'references/*/cnvkit_*'
            ],
            [
                path: { "${params.outdir}/pon/loo_qc" },
                mode: params.publish_dir_mode,
                pattern: 'loo_qc/**'
            ]
        ]
    }
    withName: 'BUILD_SEX_PON' {
        publishDir = [
            path: { "${params.outdir}/pon" },
            mode: params.publish_dir_mode,
            pattern: '{cnvkit_pon_male.cnn,cnvkit_pon_female.cnn,cnvkit_pon_sex_assignment.tsv}'
        ]
    }
}
