/*
 * conf/site_template.config
 *
 * Template for a new server. Copy to conf/<yoursite>.config, fill in the paths,
 * and run with -profile <yoursite>,singularity.
 *
 * Two ways to run on a fresh server:
 *
 * A. Containers-only (recommended for portability)
 *    Don't install any tools by hand. Pull bioconda containers for everything.
 *    Just set the reference + panel paths below. The pipeline will pull
 *    quay.io/biocontainers/... images on first run.
 *
 * B. Local installs (faster but more setup work)
 *    Install the same conda envs you had on gandalf and point at them here.
 */

params {

    // ---- Required: reference + panel ------------------------------------
    pipeline_root      = '/path/to/your/pipeline_root'

    reference          = "${params.pipeline_root}/references/Homo_sapiens_assembly38.masked.fasta"
    bed                = "${params.pipeline_root}/panel.bed"
    pindel_bed         = "${params.pipeline_root}/pindel_targets.bed"
    adapters           = "${params.pipeline_root}/illumina_adapters.fa"

    // ---- CNV resources (build with -entry BUILD_PON) -------------------
    cnv_pon            = "${params.pipeline_root}/pon/pon_reference.cnn"
    cnv_loo_summary    = "${params.pipeline_root}/pon/loo_summary.tsv"
    cnv_noise_profile  = "${params.pipeline_root}/pon/loo_bin_noise_profile.tsv"
    cnv_noisy_bins     = "${params.pipeline_root}/pon/cnvkit_noisy_bins.bed"

    // ---- SNV blacklist --------------------------------------------------
    snv_blacklist      = "${params.pipeline_root}/blacklist_snvs_hg38.tsv"

    // ---- Annotation -----------------------------------------------------
    vep_cache          = "${params.pipeline_root}/vep_cache"
    annovar_db         = "${params.pipeline_root}/annovar_db"

    // ---- FLT3 ensemble --------------------------------------------------
    flt3_container     = 'singularity'

    // If using strategy B (local installs), uncomment and fill in:
    // vardict_bin     = '/path/to/VarDict'
    // getitd_path     = '/path/to/getitd.py'
    // filt3r_bin      = '/path/to/filt3r'
    // filt3r_ref      = '/path/to/flt3_exon14-15.fa'
    // pindel_dir      = '/path/to/pindel'

    // ---- Resource limits for this machine -------------------------------
    max_memory         = '128.GB'
    max_cpus           = 16
    max_time           = '48.h'
}

// ---------------------------------------------------------------------------
// Strategy A: pull containers fresh (skip the beforeScript block, let nf-core
// modules use their declared container directives).
// ---------------------------------------------------------------------------
// (No process.beforeScript needed -- containers handle everything.)

// ---------------------------------------------------------------------------
// Strategy B: use local conda envs (uncomment the beforeScript block):
// ---------------------------------------------------------------------------
// process {
//     beforeScript = '''
//         export PATH=/your/path/to/conda/envs/targeted-seq/bin:$PATH
//     '''
//     withName: 'STRELKA|PLATYPUS' {
//         beforeScript = '''
//             export PATH=/your/path/to/conda/envs/py2/bin:/your/path/to/conda/envs/targeted-seq/bin:$PATH
//         '''
//     }
// }

// ---------------------------------------------------------------------------
// Executor: pick one
// ---------------------------------------------------------------------------
process.executor = 'local'      // or 'slurm', 'sge', 'awsbatch', ...

// On SLURM:
// process.queue = 'normal'
// process.clusterOptions = '--account=your_account'

// ---------------------------------------------------------------------------
// Container runtime
// ---------------------------------------------------------------------------
singularity {
    enabled        = true
    autoMounts     = true
    cacheDir       = "${params.pipeline_root}/singularity_cache"
}

docker {
    enabled        = false
}
