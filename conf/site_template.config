/*
 * conf/site_template.config
 *
 * Template for a new server. Copy to conf/<yoursite>.config, fill in the
 * placeholders, register the profile in nextflow.config, and run with
 *     -profile <yoursite>,singularity
 *
 * See docs/INSTALL.md for the full install recipe (prerequisites, reference
 * data, VariantValidator REST stack, container catalogue).
 *
 * Two ways to run on a fresh server:
 *
 * A. Containers-only (recommended for portability)
 *    Don't install any tools by hand. Singularity (or Docker) pulls every
 *    process container on first run. Just set the reference + panel paths.
 *
 * B. Local installs (faster on a host that already has the tools)
 *    Install the same conda envs you had on gandalf and point at them via
 *    process.beforeScript and the ext.* tool-path overrides (the commented
 *    blocks at the bottom of this file).
 */

// ---------------------------------------------------------------------------
// Parameter values for this site
// ---------------------------------------------------------------------------
params {

    // ---- Root directory holding references, bedfiles, software ---------
    // Layout expected under pipeline_root (see docs/INSTALL.md):
    //   ${pipeline_root}/references/hg38_broad/           # masked FASTA + indexes
    //   ${pipeline_root}/references/dbSNPGATK_hg38/       # Broad bundle VCFs
    //   ${pipeline_root}/references/vep_cache/            # VEP cache
    //   ${pipeline_root}/bedfiles/                        # panel BEDs
    //   ${pipeline_root}/software/annovar/                # ANNOVAR install
    pipeline_root      = '/path/to/your/pipeline_root'

    // ---- Required: reference + panel ------------------------------------
    reference          = "${params.pipeline_root}/references/hg38_broad/Homo_sapiens_assembly38.masked.fasta"
    bed                = "${params.pipeline_root}/bedfiles/MYOPOOL_240125_UBTF_hg38.bed"
    exonwise_bed       = "${params.pipeline_root}/bedfiles/MYOPOOL_240125_UBTF_Exonwise_hg38.bed"
    pindel_bed         = "${projectDir}/references/pindel_targets_flt3_ubtf.bed"
    adapters           = "${params.pipeline_root}/references/illumina_adapters.fa"

    // ---- Required: Broad-bundle VCFs (BQSR + Mutect2) ------------------
    dbsnp_vcf          = "${params.pipeline_root}/references/dbSNPGATK_hg38/Homo_sapiens_assembly38.dbsnp138.vcf.gz"
    mills_vcf          = "${params.pipeline_root}/references/dbSNPGATK_hg38/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
    gnomad_af_only     = "${params.pipeline_root}/references/dbSNPGATK_hg38/af-only-gnomad.hg38.vcf.gz"

    // ---- Required: annotation databases --------------------------------
    vep_cache          = "${params.pipeline_root}/references/vep_cache"
    annovar_script     = "${params.pipeline_root}/software/annovar/table_annovar.pl"
    annovar_db         = "${params.pipeline_root}/software/annovar/humandb"

    // ---- SNV blacklist (optional but recommended) ----------------------
    snv_blacklist      = "${params.pipeline_root}/references/blacklist_snvs_hg38.tsv"

    // ---- CNV resources: defaults come from assets/<panel>/ -------------
    // Set in workflows/tspipe.nf to ${projectDir}/assets/${params.panel}/.
    // Override here ONLY when running a non-myeloid panel without seeded
    // assets, or when validating against a freshly-rebuilt PoN before the
    // assets are updated. Otherwise leave commented out and let the
    // workflow use the git-tracked assets.
    //
    // cnv_pon_male     = "${params.pipeline_root}/pon/cnvkit_pon_male.cnn"
    // cnv_pon_female   = "${params.pipeline_root}/pon/cnvkit_pon_female.cnn"
    // cnv_loo_summary  = "${params.pipeline_root}/pon/cnvkit_loo_summary.tsv"
    // cnv_noise_profile= "${params.pipeline_root}/pon/loo_bin_noise_profile.tsv"
    // cnv_noisy_bins   = "${params.pipeline_root}/pon/cnvkit_noisy_bins.bed"
    //
    // The mixed-sex cnv_pon parameter is deprecated; use the sex-stratified
    // cnv_pon_male / cnv_pon_female pair above. cnv_pon is ignored when
    // meta.sex is populated (always, in current samplesheet schema).

    // ---- Annotation references: defaults come from assets/references/ --
    // cytoband        = "${params.pipeline_root}/references/cytoBand_hg38.txt"
    // clingen         = "${params.pipeline_root}/references/ClinGen_gene_curation_list_GRCh38.tsv"

    // ---- Panel + CNV behaviour -----------------------------------------
    // panel           = 'myeloid'    // default in nextflow.config; controls
                                     //   the assets/<panel>/ namespace
    // male_reference  = true         // default in nextflow.config; pass -y to
                                     //   cnvkit (haploid X reference). Set
                                     //   false for a female-only PoN.

    // ---- FLT3 ensemble --------------------------------------------------
    flt3_container     = 'singularity'   // or 'docker' (match your runtime)
    // flt3_region     = 'chr13:28003000-28101000'   // default in nextflow.config

    // ---- Strategy B: local tool paths (only if NOT using containers) ---
    // vardict_bin     = '/path/to/VarDictJava/build/install/VarDict/bin/VarDict'
    // getitd_path     = '/path/to/getitd.py'
    // filt3r_bin      = '/path/to/filt3r'
    // filt3r_ref      = '/path/to/flt3_exon14-15.fa'

    // ---- Resource ceilings for this machine -----------------------------
    // check_max() in conf/base.config clamps per-process requests at these.
    // Sized for a modest server; bump for HPC.
    max_memory         = '128.GB'
    max_cpus           = 16
    max_time           = '240.h'
}

// ---------------------------------------------------------------------------
// Strategy A: containers-only (default)
// ---------------------------------------------------------------------------
// No process.beforeScript needed — each module's `container` directive in
// modules/local/*.nf is what Singularity/Docker picks up. Leave the
// `process { ... }` block below commented out.

// ---------------------------------------------------------------------------
// Strategy B: local conda envs (uncomment and adjust if applicable)
// ---------------------------------------------------------------------------
// Use when the host already has the conda envs that ship the bioconda tools
// (fastp, bwa-mem2, samtools, gatk4, abra2, cnvkit, freebayes, vardict,
// varscan, somaticseq) and a py2 env for Strelka and Platypus.
//
// conda {
//     enabled = false   // do NOT let Nextflow manage envs
// }
//
// env {
//     TARGETED_SEQ_ENV = '/path/to/conda/envs/targeted-seq'
//     PY2_ENV          = '/path/to/conda/envs/py2'
// }
//
// process {
//     beforeScript = '''
//         export PATH=/path/to/conda/envs/targeted-seq/bin:$PATH
//     '''
//
//     withName: 'STRELKA' {
//         ext.python2     = '/path/to/conda/envs/py2/bin/python'
//         ext.strelka_bin = '/path/to/strelka2/bin/configureStrelkaGermlineWorkflow.py'
//         beforeScript    = 'export PATH=/path/to/conda/envs/py2/bin:$PATH'
//     }
//     withName: 'PLATYPUS' {
//         beforeScript = 'export PATH=/path/to/conda/envs/py2/bin:$PATH'
//     }
//     withName: 'VARDICT' {
//         ext.vardict_helpers_dir = '/path/to/VarDictJava/build/install/VarDict/bin'
//     }
//     withName: 'GETITD' {
//         ext.getitd_path = params.getitd_path
//     }
//     withName: 'FILT3R' {
//         ext.filt3r_bin  = params.filt3r_bin
//         ext.filt3r_ref  = params.filt3r_ref
//     }
// }

// ---------------------------------------------------------------------------
// Executor: pick the one that matches your host
// ---------------------------------------------------------------------------
process.executor = 'local'      // or 'slurm', 'sge', 'awsbatch', ...

// Tune the local executor to your machine. Defaults below are conservative;
// see conf/gandalf.config for a 192-core / 1.5 TB example.
executor {
    name           = 'local'
    cpus           = 16
    memory         = '128.GB'
    queueSize      = 8
}

// On SLURM:
// process.queue          = 'normal'
// process.clusterOptions = '--account=your_account'

// ---------------------------------------------------------------------------
// Container runtime
// ---------------------------------------------------------------------------
singularity {
    enabled        = true
    autoMounts     = true
    cacheDir       = "${params.pipeline_root}/singularity_cache"
    pullTimeout    = '60m'
    runOptions     = '--no-home'
}

docker {
    enabled        = false       // flip to true and disable singularity
                                 // if Docker is your runtime
    userEmulation  = true
}
